# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ─── Upstash Redis (optional — rate limiting) ─────────────────────────────────
# Without these the rate limiter falls back to in-memory (single-instance only).
# Create a free Redis database at https://console.upstash.com
# Then copy the REST URL and token from the database details page.
UPSTASH_REDIS_REST_URL=https://<db-name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>
