# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ─── Cloudinary (required for image uploads) ──────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<cloud-name>
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=<unsigned-upload-preset>
# Server-only — used to delete old images when users change or remove their avatar/banner
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# ─── Upstash Redis (optional — rate limiting) ─────────────────────────────────
# Without these the rate limiter falls back to in-memory (single-instance only).
# Create a free Redis database at https://console.upstash.com
# Then copy the REST URL and token from the database details page.
UPSTASH_REDIS_REST_URL=https://<db-name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>
